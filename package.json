{
  "name": "quasar-image-processing",
  "version": "0.0.1",
  "description": "A Quasar Project",
  "productName": "Quasar App",
  "author": "banhyungil <byban4186@gmail.com>",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:gen": "playwright codegen --output e2e/recorded.spec.ts --viewport-size=1920,1080 http://localhost:9000",
    "dev": "quasar dev",
    "build": "quasar build",
    "postinstall": "quasar prepare",
    "gen:types": "openapi-typescript http://localhost:8000/openapi.json -o src/types/api.d.ts"
  },
  "dependencies": {
    "@dagrejs/dagre": "^2.0.4",
    "@guolao/vue-monaco-editor": "^1.6.0",
    "@quasar/extras": "^1.16.4",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.2.1",
    "monaco-editor": "^0.55.1",
    "openseadragon": "^6.0.1",
    "pinia": "^3.0.1",
    "quasar": "^2.16.0",
    "uuid": "^13.0.0",
    "vue": "^3.5.22",
    "vue-draggable-next": "^2.3.0",
    "vue-router": "^5.0.0",
    "vue3-zoomer": "^1.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@playwright/test": "^1.58.2",
    "@quasar/app-vite": "^2.4.1",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^20.5.9",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.4.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.2",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^10.4.0",
    "globals": "^16.4.0",
    "happy-dom": "^20.8.4",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.6",
    "prettier": "^3.3.3",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite-plugin-checker": "^0.11.0",
    "vitest": "^4.1.0",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.0.7"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1",
    "pnpm": ">= 10.0.0"
  }
}
